{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build all cpp",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "d:/mingw64/bin/g++.exe -g *.cpp -o main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
